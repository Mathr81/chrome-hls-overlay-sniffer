{
  "manifest_version": 3,
  "name": "HLS Sniffer Pro",
  "version": "2.0",
  "description": "Détecte les flux HLS, résolution réelle et overlay compatible plein écran.",
  "permissions": [
    "webRequest",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-overlay": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Afficher/Cacher les stats HLS"
    }
  }
}